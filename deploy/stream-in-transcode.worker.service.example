# Copiar al servidor del worker:
#   sudo cp stream-in-transcode.worker.service.example /etc/systemd/system/stream-in-transcode.service
# Ajustar User, Group y rutas si difieren; luego:
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now stream-in-transcode.service
#   sudo journalctl -u stream-in-transcode -f

[Unit]
Description=Stream-in HLS transcode worker (BullMQ)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/apps/stream-in/server
EnvironmentFile=/home/deploy/apps/stream-in/server/.env
ExecStart=/usr/bin/node /home/deploy/apps/stream-in/server/workers/transcodeWorker.js
Restart=always
RestartSec=10
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
