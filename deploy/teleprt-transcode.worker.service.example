# Copiar al servidor del worker:
#   sudo cp teleprt-transcode.worker.service.example /etc/systemd/system/teleprt-transcode.service
# Ajustar User, Group y rutas si difieren; luego:
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now teleprt-transcode.service
#   sudo journalctl -u teleprt-transcode -f

[Unit]
Description=teleprt HLS transcode worker (BullMQ)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/apps/teleprt/server
EnvironmentFile=/home/deploy/apps/teleprt/server/.env
ExecStart=/usr/bin/node /home/deploy/apps/teleprt/server/workers/transcodeWorker.js
Restart=always
RestartSec=10
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
