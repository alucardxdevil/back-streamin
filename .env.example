# ─── Base de Datos ────────────────────────────────────────────────────────────
DB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/streamin?retryWrites=true&w=majority
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Protección de Video ──────────────────────────────────────────────────────
# Dominios autorizados para acceder al proxy de streaming (separados por coma)
# Ejemplo producción: https://stream-in.pages.dev,https://tudominio.com
# En desarrollo se agregan localhost:3000 y localhost:5000 automáticamente
# IMPORTANTE: Agregar el dominio de Cloudflare Pages en producción
ALLOWED_ORIGINS=https://stream-in.pages.dev

# Secret para firmar tokens de sesión anónimos (diferente al JWT de usuarios)
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=cambia_este_secret_en_produccion_con_valor_aleatorio_largo

# Duración del token de sesión anónimo en segundos (default: 1800 = 30 min)
SESSION_TOKEN_TTL_SECONDS=1800

# TTL de las URLs firmadas internas del proxy en segundos (default: 1200 = 20 min)
SIGNED_URL_TTL_SECONDS=1200

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Ventana de tiempo para rate limiting del proxy de streaming (ms, default: 900000 = 15 min)
STREAM_RATE_WINDOW_MS=900000
# Máximo de solicitudes al proxy de streaming por IP en la ventana (default: 120)
STREAM_RATE_MAX=120

# Ventana de tiempo para rate limiting de emisión de sesiones (ms, default: 900000 = 15 min)
SESSION_RATE_WINDOW_MS=900000
# Máximo de solicitudes de sesión por IP en la ventana (default: 20)
SESSION_RATE_MAX=20

# Máximo de solicitudes de metadata de video por IP en la ventana (default: 200)
VIDEO_META_RATE_MAX=200

# Desactivar rate limiting en desarrollo (true/false)
DISABLE_RATE_LIMIT=false

# ─── Logging ──────────────────────────────────────────────────────────────────
# Nivel de log: error, warn, info, debug (default: info)
LOG_LEVEL=info

# ─── Backblaze B2 ─────────────────────────────────────────────────────────────
# Obtener en: https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=tu_key_id_aqui
B2_APP_KEY=tu_app_key_aqui
B2_BUCKET_NAME=streamin-videos
B2_REGION=us-east-005
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# URL pública del bucket (para acceso directo sin CDN)
# Formato: https://f{nnn}.backblazeb2.com/file/{bucket-name}
B2_PUBLIC_URL=https://f005.backblazeb2.com/file/streamin-videos

# ─── CDN (Cloudflare) — Opcional ──────────────────────────────────────────────
# Cuando configures Cloudflare como CDN, cambiar esta URL
# Sin CDN: igual que B2_PUBLIC_URL
# Con CDN: https://cdn.tudominio.com
HLS_BASE_URL=https://f005.backblazeb2.com/file/streamin-videos

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Redis Cloud: redis://default:password@host:port
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Worker de Transcodificación ──────────────────────────────────────────────
# Número de jobs simultáneos por worker
# Recomendado: 1 para 1 vCPU, 2 para 2 vCPU, etc.
WORKER_CONCURRENCY=1

# Jobs máximos por minuto (rate limiting)
WORKER_RATE_LIMIT=10

# Directorio temporal para archivos de transcodificación
# En Linux/Mac: /tmp/transcode
# En Windows: C:/temp/transcode
TEMP_DIR=/tmp/transcode

# Ruta a FFmpeg (dejar vacío para usar @ffmpeg-installer/ffmpeg)
# En Linux con FFmpeg instalado: /usr/bin/ffmpeg
# En Mac con Homebrew: /opt/homebrew/bin/ffmpeg
FFMPEG_PATH=

# ─── Limpieza Automática ──────────────────────────────────────────────────────
# Horas máximas que un directorio temporal puede existir antes de ser eliminado
CLEANUP_MAX_AGE_HOURS=2

# Días que se retienen los archivos raw de videos con error antes de eliminarlos
CLEANUP_ERROR_RETENTION_DAYS=7

# ─── Límites de Upload ────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
